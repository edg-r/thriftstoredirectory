# Postgres (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/thrift_store_directory?schema=public"

# Auth (Phase 1/2+)
AUTH_SECRET="replace-with-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Admin moderation access key (used to create an HttpOnly admin session cookie)
ADMIN_ACCESS_KEY=""

# Salt for hashing request fingerprints used in review anti-spam checks
REQUEST_FINGERPRINT_SALT="replace-with-random-string"

# Optional storage provider (Phase 3)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET=""
